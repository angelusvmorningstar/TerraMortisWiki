# Terra Mortis Wiki — local environment (.env is gitignored; never commit real values)

# --- Discord OAuth2 -----------------------------------------------------------
# Reuse the SAME Discord application as TM Suite. Register this repo's redirect
# URI as an ADDITIONAL entry on that existing app (see README "Discord OAuth
# setup"). `identify` scope only. These are used server-side only and are never
# logged or returned in a response.
#
# DISCORD_REDIRECT_URI must point at the login PAGE (a static frontend route,
# served by Netlify/http-server), never a backend route directly — Discord's
# redirect is always a browser GET, which a POST-only route can never receive
# (see specs/architecture.md "Auth — port, don't reinvent...").
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/login.html

# --- Live, read-only Mongo connection (server/db.js + server/mongo-store.js) --
# The API queries tm_suite directly, per request — no snapshot, no rebuild
# step. Use a READ-ONLY Atlas database user (provisioned manually in the Atlas
# console — see README "Read-only setup").
MONGODB_URI=
# MONGODB_DB=tm_suite

# --- CORS (local dev only) -----------------------------------------------------
# Only relevant when the static frontend (e.g. :8080) and this API (:3000) run
# on different origins locally. In production the Netlify redirect proxy makes
# every request same-origin, so this is mostly inert there.
# CORS_ORIGIN=http://localhost:8080

# --- Server -------------------------------------------------------------------
# PORT=3000
# NODE_ENV=development
