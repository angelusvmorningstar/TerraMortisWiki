# Terra Mortis Wiki — local environment (.env is gitignored; never commit real values)

# --- Discord OAuth2 -----------------------------------------------------------
# Reuse the SAME Discord application as TM Suite. Register this repo's redirect
# URI as an ADDITIONAL entry on that existing app (see README "Discord OAuth
# setup"). `identify` scope only. These are used server-side only and are never
# logged or returned in a response.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# --- Snapshot generation (scripts/snapshot.mjs, ST-only, manual) --------------
# Read-only connection string for reading tm_suite. The deployed Wiki service
# does NOT use this — only the snapshot script does.
# MONGODB_URI=
# MONGODB_DB=tm_suite

# --- Server -------------------------------------------------------------------
# PORT=3000
# NODE_ENV=development
